# Copy to `.env` in this directory (never commit `.env`).
# Google AI — required for `npm run route`, `triage`, `distill`, `rank`, etc.
GEMINI_API_KEY=

# Vercel API — optional; used by `npm run vercel-bridge` (deployment checks)
#
# VERCEL_TOKEN: Personal Access Token from https://vercel.com/account/tokens
#   Required scope: "deployments:read" (minimum).
#   Full-access tokens also work. The code sends: Authorization: Bearer <token>
#   Using the legacy "Token <token>" format causes a 403 — Bearer is correct.
#   Do NOT prefix the value with "Bearer" here; the code adds that automatically.
VERCEL_TOKEN=
#
# VERCEL_PROJECT_ID: The prj_... ID from Vercel → Project → Settings → General.
#   Using the human-readable project name instead of the prj_ ID causes a 403.
VERCEL_PROJECT_ID=
#
# VERCEL_TEAM_ID: Required if the project belongs to a Vercel Team.
#   Find it at Vercel → Team Settings → General. Starts with "team_".
#   Omitting this when the project is team-owned causes a 403.
# VERCEL_TEAM_ID=
#
# VERCEL_AUTOMATION_BYPASS_SECRET: Used by `npm run sync-hook` (Puppeteer screenshot).
#   Required only when the deployment has Vercel Authentication / Deployment Protection
#   enabled. Without it, Puppeteer gets a 403 before it can take a screenshot.
#   Generate the secret at: Vercel → Project → Settings → Deployment Protection →
#   "Protection Bypass for Automation" → enable and copy the secret.
# VERCEL_AUTOMATION_BYPASS_SECRET=

# Biometrics — required for `npm run rank`. REAL DATA ONLY.
# A live bridge (WHOOP / Muse / Apple Health) must write real values to the
# state file below. There is no mock, demo, or fixture mode — if the file is
# missing, empty, or invalid, task ranking aborts rather than guess.
# BIOMETRICS_STATE_FILE=notes/biometric-state.json
# BIOMETRICS_TREND_FILE=notes/biometric-trends.json
