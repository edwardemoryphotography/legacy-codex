# Copy to `.env` in this directory (never commit `.env`).
# Google AI — required for `npm run route`, `triage`, `distill`, `rank`, etc.
GEMINI_API_KEY=

# Vercel API — optional; used by `npm run vercel-bridge` (deployment checks)
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
# Optional if the project is under a team
# VERCEL_TEAM_ID=

# Biometrics — required for `npm run rank`. REAL DATA ONLY.
# A live bridge (WHOOP / Muse / Apple Health) must write real values to the
# state file below. There is no mock, demo, or fixture mode — if the file is
# missing, empty, or invalid, task ranking aborts rather than guess.
# BIOMETRICS_STATE_FILE=notes/biometric-state.json
# BIOMETRICS_TREND_FILE=notes/biometric-trends.json
